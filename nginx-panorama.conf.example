# Exemplo de bloco Nginx para o Panorama, para ADICIONAR ao lado do(s)
# bloco(s) que já existem para o Whaticket (não substituir nada existente).
#
# Uso:
#   1. sudo cp nginx-panorama.conf.example /etc/nginx/sites-available/panorama
#   2. Trocar "painel.seudominio.com.br" pelo subdomínio real
#   3. sudo ln -s /etc/nginx/sites-available/panorama /etc/nginx/sites-enabled/
#   4. sudo nginx -t   (testa a config antes de recarregar)
#   5. sudo certbot --nginx -d painel.seudominio.com.br
#   6. sudo systemctl reload nginx

server {
    listen 80;
    server_name painel.seudominio.com.br;

    # ATENÇÃO: o frontend React (Fase 3) ainda não existe. Por enquanto,
    # "/" também aponta para a API, só para dar para testar /health e
    # os endpoints /api/* pelo domínio público. Quando o frontend estiver
    # pronto, troque este location para "proxy_pass http://127.0.0.1:3002;"
    location / {
        proxy_pass http://127.0.0.1:3001;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }

    # API do Panorama
    location /api/ {
        proxy_pass http://127.0.0.1:3001/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # WebSocket (Socket.io, para status em tempo real no dashboard)
    location /socket.io/ {
        proxy_pass http://127.0.0.1:3001/socket.io/;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
    }
}

# Depois de rodar o certbot (passo 5 acima), ele mesmo edita este arquivo
# e adiciona um bloco "listen 443 ssl" com o certificado — não precisa
# escrever isso manualmente.
